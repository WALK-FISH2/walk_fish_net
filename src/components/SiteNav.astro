---
import { SITE_CONFIG, sitePath } from "../config/site.config";

interface Props { floating?: boolean; }
const { floating = false } = Astro.props;
const pathname = Astro.url.pathname;
const current = (href: string) => href === "/" ? pathname === sitePath("/") : pathname.startsWith(sitePath(href));
---

<header class:list={["site-nav", floating && "site-nav--floating"]} data-site-nav>
  <a class="site-brand" href={sitePath("/")} aria-label={`${SITE_CONFIG.name}首页`}>
    <span class="brand-sprite" aria-hidden="true"></span>
    <span><strong>{SITE_CONFIG.shortName}</strong><small>WORLD 02</small></span>
  </a>
  <nav class="desktop-nav" aria-label="主导航">
    {SITE_CONFIG.nav.map((item) => <a href={sitePath(item.href)} aria-current={current(item.href) ? "page" : undefined}>{item.label}</a>)}
  </nav>
  <button class="menu-button pixel-button" type="button" aria-expanded="false" aria-controls="mobile-navigation" data-menu-open>
    <span aria-hidden="true">≡</span><span class="sr-only">打开菜单</span>
  </button>
  <div id="mobile-navigation" class="mobile-nav" role="dialog" aria-modal="true" aria-label="移动端导航" hidden data-menu-panel>
    <div class="mobile-nav__stars" aria-hidden="true"></div>
    <p class="eyebrow">SELECT AREA</p>
    <nav aria-label="移动端主导航">
      {SITE_CONFIG.nav.map((item, index) => <a href={sitePath(item.href)}><span>0{index + 1}</span>{item.label}</a>)}
    </nav>
    <button class="text-button" type="button" data-menu-close>关闭 / ESC</button>
  </div>
</header>

<script>
  const nav = document.querySelector<HTMLElement>("[data-site-nav]");
  const openButton = nav?.querySelector<HTMLButtonElement>("[data-menu-open]");
  const closeButton = nav?.querySelector<HTMLButtonElement>("[data-menu-close]");
  const panel = nav?.querySelector<HTMLElement>("[data-menu-panel]");
  let previousOverflow = "";

  const closeMenu = () => {
    if (!panel || !openButton) return;
    panel.hidden = true;
    openButton.setAttribute("aria-expanded", "false");
    openButton.querySelector("[aria-hidden]")!.textContent = "≡";
    document.body.style.overflow = previousOverflow;
    openButton.focus();
  };
  const openMenu = () => {
    if (!panel || !openButton) return;
    previousOverflow = document.body.style.overflow;
    panel.hidden = false;
    openButton.setAttribute("aria-expanded", "true");
    openButton.querySelector("[aria-hidden]")!.textContent = "×";
    document.body.style.overflow = "hidden";
    panel.querySelector<HTMLAnchorElement>("a")?.focus();
  };
  openButton?.addEventListener("click", () => panel?.hidden ? openMenu() : closeMenu());
  closeButton?.addEventListener("click", closeMenu);
  panel?.querySelectorAll("a").forEach((link) => link.addEventListener("click", closeMenu));
  document.addEventListener("keydown", (event) => {
    if (!panel || panel.hidden) return;
    if (event.key === "Escape") closeMenu();
    if (event.key !== "Tab") return;
    const items = Array.from(panel.querySelectorAll<HTMLElement>("a, button"));
    const first = items[0];
    const last = items[items.length - 1];
    if (event.shiftKey && document.activeElement === first) { event.preventDefault(); last.focus(); }
    if (!event.shiftKey && document.activeElement === last) { event.preventDefault(); first.focus(); }
  });
</script>

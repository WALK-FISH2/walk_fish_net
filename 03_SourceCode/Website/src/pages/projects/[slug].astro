---
import { getCollection } from "astro:content";
import LegacyRedirect from "../../components/LegacyRedirect.astro";
import { entrySlug, sortPrograms } from "../../lib/content";

export async function getStaticPaths() {
  const entries = sortPrograms(await getCollection("programs", ({ data }) => !data.draft));
  return entries.map((entry) => ({ params: { slug: entrySlug(entry) } }));
}

const { slug } = Astro.params;
---

<LegacyRedirect targetPath={"/programs/" + slug + "/"} />

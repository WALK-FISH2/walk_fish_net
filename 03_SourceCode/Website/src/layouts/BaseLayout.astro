---
import "../styles/global.css";
import { SITE_CONFIG, sitePath } from "../config/site.config";
import { MOTION_STORAGE_KEY } from "../lib/motionPreference";

interface Props {
  title?: string;
  description?: string;
  theme?: "land" | "sea" | "space";
  canonicalPath?: string;
  noShell?: boolean;
}

const {
  title = SITE_CONFIG.title,
  description = SITE_CONFIG.description,
  theme = "space",
  canonicalPath = Astro.url.pathname,
  noShell = false,
} = Astro.props;
const fullTitle = title === SITE_CONFIG.title ? title : `${title} · ${SITE_CONFIG.name}`;
const canonical = new URL(sitePath(canonicalPath), Astro.site ?? Astro.url.origin);
const ogImage = new URL(sitePath("/og-v2.png"), Astro.site ?? Astro.url.origin);
const motionStorageKey = MOTION_STORAGE_KEY;
---

<!doctype html>
<html lang="zh-CN" data-motion-mode="full" data-motion-source="default" data-system-motion="no-preference">
  <head>
    <script is:inline define:vars={{ motionStorageKey }}>
      (() => {
        const params = new URLSearchParams(window.location.search);
        const queryMode = params.get("motion");
        let mode = queryMode === "full" || queryMode === "reduce" ? queryMode : null;
        let source = mode ? "url" : "default";
        if (!mode) {
          try {
            const savedMode = window.localStorage.getItem(motionStorageKey);
            if (savedMode === "full" || savedMode === "reduce") {
              mode = savedMode;
              source = "saved";
            }
          } catch {
            // Storage is optional; the product default remains usable.
          }
        }
        const systemReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        document.documentElement.dataset.motionMode = mode || "full";
        document.documentElement.dataset.motionSource = source;
        document.documentElement.dataset.systemMotion = systemReduced ? "reduce" : "no-preference";
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#181443" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href={sitePath("/favicon.svg")} />
    <link rel="manifest" href={sitePath("/manifest.webmanifest")} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="zh_CN" />
    <meta property="og:site_name" content={SITE_CONFIG.name} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <title>{fullTitle}</title>
  </head>
  <body class:list={[!noShell && "page-shell", !noShell && `page-shell--${theme}`]}>
    <a class="skip-link" href="#main-content">跳到主要内容</a>
    <slot />
  </body>
</html>

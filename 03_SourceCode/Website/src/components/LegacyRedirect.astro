---
import { SITE_CONFIG, sitePath } from "../config/site.config";

interface Props {
  targetPath: string;
}

const { targetPath } = Astro.props;
const target = sitePath(targetPath);
const canonical = new URL(target, Astro.site ?? Astro.url.origin);
const title = "页面已迁移 · " + SITE_CONFIG.name;
const redirectScript = "window.location.replace(" + JSON.stringify(target) + ");";
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta http-equiv="refresh" content={"0;url=" + target} />
    <meta name="robots" content="noindex,follow" />
    <link rel="canonical" href={canonical} />
    <title>{title}</title>
    <script is:inline set:html={redirectScript} />
  </head>
  <body>
    <main>
      <h1>“做点啥呢”已迁移</h1>
      <p>旧地址继续保留，正在前往新的 Programs 页面。</p>
      <p><a href={target}>如果没有自动跳转，请点击这里继续。</a></p>
    </main>
  </body>
</html>
